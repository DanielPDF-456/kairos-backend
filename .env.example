# KAIROS - Configuración de Entorno
# Copia este archivo a .env en el directorio backend

# Flask
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=tu-llave-secreta-super-segura-cambia-esto-en-produccion

# Base de datos en Render (PostgreSQL)
# Formato: postgresql://usuario:contraseña@host:puerto/nombre_base_datos
# Ejemplo para desarrollo local:
# DATABASE_URL=postgresql://postgres:password@localhost:5432/kairos_db

# Para Render:
# 1. Crear una instancia PostgreSQL en https://render.com/
# 2. Copiar la "Internal Database URL" 
# 3. Pegarla aquí:
DATABASE_URL=postgresql://usuario:contraseña@host.render.com:5432/kairos_db

# Puerto
PORT=5000

# CORS
CORS_ORIGINS=*

# Notificaciones (opcional para futuras integraciones)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=tu-email@gmail.com
SMTP_PASSWORD=tu-contraseña-app

# Configuración de alarmas
ALERTA_RETRASO_CRITICO_MINUTOS=30
ALERTA_ANTICIPADA_MINUTOS=5
